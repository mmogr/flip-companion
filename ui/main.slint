// Flip Companion — root UI layout for the bottom screen.
// Three tabs: Keyboard, Stats, Apps.
// All touch targets are ≥48px for finger-friendly operation.

import { Keyboard } from "keyboard.slint";
import { Stats } from "stats.slint";
import { Shuttle } from "shuttle.slint";
import { Apps } from "apps.slint";
import { TopBar } from "top_bar.slint";
import { StatsStore } from "globals.slint";
import { ShuttleStore } from "globals.slint";
import { AppStore } from "globals.slint";
export { StatsStore }
export { ShuttleStore }
export { AppStore }

component TabButton inherits Rectangle {
    in property <string> label;
    in property <bool> active;
    callback clicked();

    horizontal-stretch: 1;
    border-radius: 8px;
    background: active ? #0f3460 : transparent;

    TouchArea {
        clicked => { root.clicked(); }
    }

    Text {
        text: label;
        font-size: 22px;
        color: active ? #e94560 : #a0a0b8;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

export component App inherits Window {
    title: "Flip Companion";
    preferred-width: 480px;
    preferred-height: 800px;
    background: #1a1a2e;

    // Track which tab is active: 0=Keyboard, 1=Stats, 2=Apps
    in-out property <int> active-tab: 0;

    // --- Callbacks for backend communication (wired in Rust via mpsc) ---
    callback key-pressed(string);
    callback shuttle-window(string, string); // window_id, direction ("up"/"down")
    callback request-refresh();
    callback launch-app(int);  // app index from AppStore.apps
    callback close-app();
    callback ui-focus-changed(bool);  // true = Slint TextInput focused, false = unfocused
    callback active-tab-changed(int); // notify Rust when the active tab changes

    VerticalLayout {
        // Top status bar — always visible
        TopBar {}

        // Content area — fills available space
        Rectangle {
            vertical-stretch: 1;

            Keyboard {
                visible: active-tab == 0;
                key-pressed(key) => { root.key-pressed(key); }
            }
            Stats {
                visible: active-tab == 1;
            }
            Shuttle {
                visible: active-tab == 2 && !AppStore.is-running;
                shuttle-window(id, dir) => { root.shuttle-window(id, dir); }
                request-refresh() => { root.request-refresh(); }
            }
            Apps {
                visible: active-tab == 2;
                launch-app(idx) => { root.launch-app(idx); }
                close-app() => { root.close-app(); }
            }
        }

        // Tab bar at the bottom — always visible
        Rectangle {
            height: 56px;
            background: #16213e;

            HorizontalLayout {
                padding: 4px;
                spacing: 4px;

                TabButton {
                    label: "⌨️";
                    active: active-tab == 0;
                    clicked => { active-tab = 0; root.active-tab-changed(0); }
                }
                TabButton {
                    label: "📊";
                    active: active-tab == 1;
                    clicked => { active-tab = 1; root.active-tab-changed(1); }
                }
                TabButton {
                    label: AppStore.is-running && active-tab == 2 ? "✕" : "🚀";
                    active: active-tab == 2;
                    clicked => {
                        if (AppStore.is-running && active-tab == 2) {
                            root.close-app();
                        } else {
                            active-tab = 2;
                            root.active-tab-changed(2);
                        }
                    }
                }
            }
        }
    }
}
