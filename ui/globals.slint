// Global state singletons — Rust backend writes to these via
// app.global::<Store>().set_*() through upgrade_in_event_loop().
// UI components read from these directly.

export global StatsStore {
    in-out property <float> cpu-usage: 0;
    in-out property <float> cpu-temp: 0;
    in-out property <float> gpu-usage: 0;
    in-out property <float> gpu-temp: 0;
    in-out property <float> mem-used-gb: 0;
    in-out property <float> mem-total-gb: 16;
    in-out property <float> battery-percent: 0;
    in-out property <bool> battery-charging: false;
    in-out property <string> clock-text: "--:--";
    in-out property <[float]> cpu-history;
    in-out property <[float]> gpu-history;
    in-out property <[float]> mem-history;
}

// A single entry in the window list shown by the shuttle panel.
export struct WindowEntry {
    id: string,
    caption: string,
    output: string,
}

export global ShuttleStore {
    in-out property <[WindowEntry]> windows;
}
