// Stats panel — system stats dashboard.

import { StatsStore } from "globals.slint";

component StatRow inherits Rectangle {
    in property <string> label;
    in property <string> value;
    in property <float> percent;

    height: 44px;
    background: #16213e;
    border-radius: 6px;

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        alignment: space-between;

        Text {
            text: label;
            font-size: 14px;
            color: #a0a0b8;
            vertical-alignment: center;
        }
        Text {
            text: value;
            font-size: 14px;
            color: #e0e0f0;
            vertical-alignment: center;
        }
    }

    // Progress bar overlay
    Rectangle {
        x: 0;
        y: parent.height - 3px;
        height: 3px;
        width: parent.width * clamp(percent, 0, 1);
        background: percent > 0.85 ? #e94560 : percent > 0.6 ? #f0a500 : #0f3460;
        border-radius: 1.5px;
    }
}

export component Stats inherits Rectangle {
    background: #1a1a2e;

    VerticalLayout {
        alignment: start;
        padding: 16px;
        spacing: 12px;

        Text {
            text: "System Stats";
            font-size: 20px;
            color: #e0e0f0;
            horizontal-alignment: center;
        }

        StatRow { label: "CPU"; value: Math.round(StatsStore.cpu-usage) + "%"; percent: StatsStore.cpu-usage / 100; }
        StatRow { label: "CPU Temp"; value: Math.round(StatsStore.cpu-temp) + "°C"; percent: StatsStore.cpu-temp / 100; }
        StatRow { label: "GPU"; value: Math.round(StatsStore.gpu-usage) + "%"; percent: StatsStore.gpu-usage / 100; }
        StatRow { label: "GPU Temp"; value: Math.round(StatsStore.gpu-temp) + "°C"; percent: StatsStore.gpu-temp / 100; }
        StatRow {
            label: "RAM";
            value: Math.round(StatsStore.mem-used-gb * 10) / 10 + " / " + Math.round(StatsStore.mem-total-gb * 10) / 10 + " GB";
            percent: StatsStore.mem-total-gb > 0 ? StatsStore.mem-used-gb / StatsStore.mem-total-gb : 0;
        }
        StatRow {
            label: StatsStore.battery-charging ? "Battery ⚡" : "Battery";
            value: Math.round(StatsStore.battery-percent) + "%";
            percent: StatsStore.battery-percent / 100;
        }
    }
}
