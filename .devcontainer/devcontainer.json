{
  "name": "Flip Companion",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "slint.slint",
        "tamasfe.even-better-toml",
        "serayuzgur.crates",
        "github.copilot",
        "github.copilot-chat"
      ],
      "settings": {
        "rust-analyzer.check.command": "clippy",
        "editor.formatOnSave": true
      }
    }
  },
  "postCreateCommand": "cargo fetch",
  "mounts": [
    "source=flip-companion-cargo-registry,target=/usr/local/cargo/registry,type=volume",
    "source=flip-companion-cargo-git,target=/usr/local/cargo/git,type=volume",
    "source=flip-companion-target,target=${containerWorkspaceFolder}/target,type=volume"
  ],
  "remoteUser": "vscode"
}
